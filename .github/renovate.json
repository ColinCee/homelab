{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:enableMajor"],
  "packageRules": [
    {
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],
  "docker-compose": {
    "fileMatch": ["stacks/.+/compose\\.yaml$"]
  }
}
